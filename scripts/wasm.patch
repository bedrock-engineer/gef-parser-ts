+// WASM wrapper around the parse function.
+#[cfg(feature = "wasm")]
+#[wasm_bindgen]
+pub fn parse_gef_wasm(gef: &str) -> std::result::Result<JsValue, JsValue> {
+    // Set up console error panic hook for better debugging
+    #[cfg(feature = "wasm")]
+    console_error_panic_hook::set_once();
+
+    let (data, headers) = parse(gef)
+        .map_err(|e| JsValue::from_str(&format!("Parse error: {}", e)))?;
+    
+    let result = GefParseResult {
+        data: data.to_string(),
+        headers: headers.into(),
+    };
+    
+    serde_wasm_bindgen::to_value(&result)
+        .map_err(|e| JsValue::from_str(&format!("Serialization error: {}", e)))
